### JetBrains Specific

# File-based project format
*.iws

# CMake
# This is the default naming convention use for generating cmake builds.
# If the user did not configure there project properly then this is here to prevent an accidental push of these files
cmake-build-*/

# libFuzzer corpus, seeds, and crash artifacts (build tree only)
fuzzing/corpus/
fuzzing/seeds/
fuzzing/artifacts/
fuzzing/crash-*
fuzzing/timeout-*
fuzzing/leak-*
fuzzing/oom-*
fuzzing/slow-unit-*
fuzzing/minimize-crash-*

# asmlab cached reference data (Agner Fog tables, uops.info exports); fetched on demand
tools/asmlab/refdata/*
!tools/asmlab/refdata/.gitkeep

# asmlab rendered harness TUs (from tools/asmlab/**/*.cpp.in); primary output is under /out/
tools/asmlab/harness/harness.cpp
tools/asmlab/harness/constexpr_probe.cpp
tools/asmlab/golden/harness.cpp

# Premake generated artifacts at the repository root
/Makefile
/bin/
/obj/

