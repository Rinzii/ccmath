        "base",
        "clang-libcpp",
        "RelWithDebInfo"
      ],
      "description": "Ninja + Clang + libc++ (RelWithDebInfo)"
    },
    {
      "name": "ninja-intel-relwithdebinfo",
      "inherits": [
        "base",
        "intel",
        "RelWithDebInfo"
      ],
      "description": "Ninja + Intel (RelWithDebInfo)"
