        "base-vs22",
        "Debug"
      ],
      "description": "VS2022 + Debug"
    },
    {
      "name": "vs22-release",
      "inherits": [
        "base-vs22",
        "Release"
      ],
      "description": "VS2022 + Release"
    },
    {
      "name": "vs22-release-rigorous",
      "inherits": [
        "base-vs22",
        "Release",
        "rigorous",
        "rigorous-vcpkg"
      ],
      "description": "VS2022 + Release for rigorous MPFR validation via vcpkg",
      "binaryDir": "${sourceDir}/out/build/vs22/vs22-release-rigorous"
    },
    {
      "name": "vs22-clang-debug",
      "inherits": [
        "base-vs22",
        "msvc-clang",
