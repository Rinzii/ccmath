{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 18,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "description": "Base configuration using Ninja Multi-config",
      "generator": "Ninja Multi-Config",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/ninja/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo;MinSizeRel",
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "base-clion",
      "description": "Single-config Ninja for CLion",
      "generator": "Ninja",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "base-vs19",
      "description": "Base configuration using Visual Studio 16 (2019)",
      "generator": "Visual Studio 16 2019",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/vs19/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "base-vs22",
      "description": "Base configuration using Visual Studio 17 (2022)",
      "generator": "Visual Studio 17 2022",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/vs22/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "Debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "Release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "MinSizeRel",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "RelWithDebInfo",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "ccache",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache"
      }
    },
    {
      "name": "gcc",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "clang",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "clang-libcpp",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS": "-stdlib=libc++",
        "CMAKE_EXE_LINKER_FLAGS": "-lc++abi"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "msvc-clang",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl"
      }
    },
    {
      "name": "intel",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "icx",
        "CMAKE_CXX_COMPILER": "icpx"
      }
    },
    {
      "name": "fuzz",
      "hidden": true,
      "cacheVariables": {
        "CCMATH_BUILD_FUZZING": "ON",
        "CCMATH_BUILD_TESTS": "OFF",
        "CCMATH_BUILD_EXAMPLES": "OFF",
        "CCMATH_BUILD_BENCHMARKS": "OFF",
        "CMAKE_C_FLAGS_DEBUG": "-O1",
        "CMAKE_CXX_FLAGS_DEBUG": "-O1"
      }
    },
    {
      "name": "rigorous",
      "hidden": true,
      "cacheVariables": {
        "CCMATH_BUILD_TESTS": "ON",
        "CCMATH_BUILD_SIMPLE_TESTS": "OFF",
        "CCMATH_BUILD_RIGOROUS_TESTS": "ON",
        "CCMATH_ENABLE_MPFR_TESTS": "ON",
        "CCMATH_ENABLE_SEARCH_TOOLS": "ON",
        "CCMATH_DESIRED_CXX_STANDARD": "cxx_std_20",
        "CCMATH_ENABLE_AGGRESSIVE_WARNINGS": "ON",
        "CCMATH_ENABLE_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "rigorous-coremath",
      "hidden": true,
      "cacheVariables": {
        "CCMATH_ENABLE_COREMATH_TESTS": "ON",
        "CCMATH_COREMATH_ROOT": "${sourceDir}/coremath-prefix"
      }
    },
    {
      "name": "showcase",
      "hidden": true,
      "cacheVariables": {
        "CCMATH_BUILD_SHOWCASE": "ON",
        "CCMATH_BUILD_BENCHMARKS": "ON",
        "CCMATH_BUILD_TESTS": "OFF",
        "CCMATH_SHOWCASE_ENABLE_GCEM": "ON",
        "CCMATH_SHOWCASE_ENABLE_MPFR": "ON",
        "CCMATH_DESIRED_CXX_STANDARD": "cxx_std_20"
      }
    },
    {
      "name": "examples",
      "hidden": true,
      "cacheVariables": {
        "CCMATH_BUILD_EXAMPLES": "ON",
        "CCMATH_BUILD_TESTS": "OFF",
        "CCMATH_BUILD_BENCHMARKS": "OFF",
        "CCMATH_BUILD_SHOWCASE": "OFF"
      }
    },
    {
      "name": "rigorous-vcpkg",
      "hidden": true,
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/vcpkg"
      },
      "cacheVariables": {
        "CCMATH_ENABLE_COREMATH_TESTS": "OFF",
        "VCPKG_MANIFEST_DIR": "${sourceDir}/cmake/vcpkg",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "ninja-gcc-debug",
      "inherits": [
        "base",
        "gcc",
        "Debug"
      ],
      "description": "Ninja Multi-config + GCC (Debug)"
    },
    {
      "name": "ninja-gcc-release",
      "inherits": [
        "base",
        "gcc",
        "Release"
      ],
      "description": "Ninja Multi-config + GCC (Release)"
    },
    {
      "name": "ninja-gcc-ccache-debug",
      "inherits": [
        "base",
        "ccache",
        "gcc",
        "Debug"
      ],
      "description": "Ninja Multi-config + GCC + ccache (Debug)"
    },
    {
      "name": "ninja-clang-debug",
      "inherits": [
        "base",
        "clang",
        "Debug"
      ],
      "description": "Ninja Multi-config + Clang (Debug)"
    },
    {
      "name": "clion-clang-debug",
      "displayName": "CLion Clang Debug",
      "inherits": [
        "base-clion",
        "clang",
        "Debug"
      ],
      "binaryDir": "${sourceDir}/out/clang",
      "description": "Single-config Ninja + Clang (Debug) for CLion"
    },
    {
      "name": "clion-clang-debug-examples",
      "displayName": "CLion Clang Debug + examples",
      "inherits": [
        "base-clion",
        "clang",
        "Debug",
        "examples"
      ],
      "binaryDir": "${sourceDir}/out/clang-examples",
      "description": "Single-config Ninja + Clang (Debug) for CLion examples"
    },
    {
      "name": "clion-clang-debug-rigorous-dev",
      "displayName": "CLion Clang Debug + rigorous",
      "inherits": [
        "base-clion",
        "clang",
        "Debug",
        "rigorous"
      ],
      "binaryDir": "${sourceDir}/out/clang-rigorous-dev",
      "description": "CLion Clang Debug with simple and rigorous test suites",
      "cacheVariables": {
        "CCMATH_BUILD_SIMPLE_TESTS": "ON",
        "CCMATH_ENABLE_AGGRESSIVE_WARNINGS": "OFF",
        "CCMATH_ENABLE_WARNINGS_AS_ERRORS": "OFF",
        "CCMATH_ENABLE_COREMATH_TESTS": "OFF"
      }
    },
    {
      "name": "clion-clang-release-showcase",
      "displayName": "CLion Clang Release + showcase",
      "inherits": [
        "base-clion",
        "clang",
        "Release",
        "showcase"
      ],
      "binaryDir": "${sourceDir}/out/clang-showcase",
      "description": "Single-config Release showcase comparisons for CLion"
    },
    {
      "name": "ninja-clang-debug-rigorous-dev",
      "inherits": [
        "base",
        "clang",
        "Debug",
        "rigorous",
        "rigorous-coremath"
      ],
      "description": "Clang Debug with simple and rigorous test suites for CLion",
      "cacheVariables": {
        "CCMATH_BUILD_SIMPLE_TESTS": "ON",
        "CCMATH_ENABLE_AGGRESSIVE_WARNINGS": "OFF",
        "CCMATH_ENABLE_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "ninja-clang-debug-rigorous",
      "inherits": [
        "base",
        "clang",
        "Debug",
        "rigorous",
        "rigorous-coremath"
      ],
      "description": "Clang Debug for rigorous validation only"
    },
    {
      "name": "ninja-fuzz-debug",
      "inherits": [
        "base",
        "Debug",
        "fuzz"
      ],
      "description": "Ninja Multi-config + libFuzzer (Debug)"
    },
    {
      "name": "ninja-clang-release",
      "inherits": [
        "base",
        "clang",
        "Release"
      ],
      "description": "Ninja Multi-config + Clang (Release)"
    },
    {
      "name": "ninja-clang-release-rigorous",
      "inherits": [
        "base",
        "clang",
        "Release",
        "rigorous",
        "rigorous-coremath"
      ],
      "description": "Ninja Multi-config + Clang (Release) for rigorous validation"
    },
    {
      "name": "ninja-clang-release-showcase",
      "inherits": [
        "base",
        "clang",
        "Release",
        "showcase"
      ],
      "description": "Ninja Multi-config + Clang (Release) for library showcase comparisons"
    },
    {
      "name": "ninja-gcc-release-rigorous",
      "inherits": [
        "base",
        "gcc",
        "Release",
        "rigorous",
        "rigorous-coremath"
      ],
