        },
        {
          "type": "build",
          "name": "build-clion-clang-debug-examples"
        }
      ]
    },
    {
      "name": "workflow-clion-clang-debug-rigorous-dev",
      "displayName": "CLion rigorous validation",
      "description": "Configure, build, and run rigorous ctest for CLion",
      "steps": [
        {
          "type": "configure",
          "name": "clion-clang-debug-rigorous-dev"
        },
        {
          "type": "build",
          "name": "build-clion-clang-debug-rigorous-dev"
        },
