#ifndef CCMATH_VERSION_HPP
#define CCMATH_VERSION_HPP

#define CCMATH_VERSION_MAJOR @CCMATH_VERSION_MAJOR@
#define CCMATH_VERSION_MINOR @CCMATH_VERSION_MINOR@
#define CCMATH_VERSION_PATCH @CCMATH_VERSION_PATCH@
// MAJOR.MINOR.PATCH packed into one integer, up to 3 digits (0 to 999) per component.
#define CCMATH_TO_VERSION(MAJOR, MINOR, PATCH) ((MAJOR) * 1000000 + (MINOR) * 1000 + (PATCH))
#define CCMATH_VERSION CCMATH_TO_VERSION(CCMATH_VERSION_MAJOR, CCMATH_VERSION_MINOR, CCMATH_VERSION_PATCH)

#endif // CCMATH_VERSION_HPP